            <div class="footer-section">
                <h4>Contact</h4>
                <p>Email: BosniakStudies@gmail.com</p>
                <p>Website: bosniakstudies.org</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2025 Bosniak Studies. All Rights Reserved.</p>
