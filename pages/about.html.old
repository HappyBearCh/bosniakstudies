                <span class="logo-icon"><img src="../images/logo.png" alt="Bosniak Studies Logo"></span>
                <span class="logo-text">Bosniak<br><strong>Studies</strong></span>
            </div>
            <ul class="nav-menu" id="navMenu">
                <li><a href="../index.html" class="nav-link">Home</a></li>
